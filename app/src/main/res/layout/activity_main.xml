<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?android:attr/colorBackground"
        tools:context=".MainActivity">

    <ImageView
            android:id="@+id/appIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="48dp"
            android:src="@mipmap/ic_launcher_round"
            android:contentDescription="@null"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <TextView
            android:id="@+id/Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Pock Pock"
            android:textAlignment="center"
            android:textSize="56sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary"
            android:letterSpacing="0.05"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/appIcon" />

    <com.google.android.material.button.MaterialButton
            android:id="@+id/playButton"
            android:layout_width="260dp"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:onClick="goToGameView"
            android:text="Play"
            android:textSize="18sp"
            app:cornerRadius="28dp"
            app:backgroundTint="@color/effectColor"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/Title" />

    <com.google.android.material.button.MaterialButton
            android:id="@+id/tutorialButton"
            android:layout_width="260dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:onClick="goToTutorial"
            android:text="Tutorial"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorPrimary"
            app:cornerRadius="28dp"
            app:backgroundTint="?attr/colorSecondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/playButton" />

    <com.google.android.material.button.MaterialButton
            android:id="@+id/settingsButton"
            android:layout_width="260dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:onClick="goToSettings"
            android:text="Settings"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorPrimary"
            app:cornerRadius="28dp"
            app:backgroundTint="?attr/colorSecondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tutorialButton" />

    <com.google.android.material.button.MaterialButton
            android:id="@+id/rewardedAdButton"
            android:layout_width="260dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:onClick="showAd"
            android:text="Watch Ad"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorPrimary"
            app:cornerRadius="28dp"
            app:backgroundTint="?attr/colorSecondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/settingsButton" />

    <com.google.android.material.button.MaterialButton
            android:id="@+id/ballsButton"
            android:layout_width="260dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:onClick="goToBalls"
            android:text="Balls"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorPrimary"
            app:cornerRadius="28dp"
            app:backgroundTint="?attr/colorSecondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/rewardedAdButton" />

    <com.google.android.material.button.MaterialButton
            android:id="@+id/shareButton"
            android:layout_width="260dp"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="Share"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorPrimary"
            app:cornerRadius="28dp"
            app:backgroundTint="?attr/colorSecondary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ballsButton" />

    <TextView
            android:id="@+id/AdRatioText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="16dp"
            android:text="100/100"
            android:textAlignment="textEnd"
            android:textSize="18sp"
            android:textColor="?android:attr/textColorPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
