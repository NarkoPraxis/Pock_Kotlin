    <!-- Tips shown during finger selection -->
    <string-array name="tip_scoring">
        <item>Scoring:</item>
        <item>   Hit your opponent</item>
        <item>   into either purple zone</item>
        <item>   to score a point.</item>
    </string-array>
    <string-array name="tip_charging">
        <item>Charging:</item>
        <item>   Hold to build power.</item>
        <item>   Release when purple</item>
        <item>   Gain a shield!</item>
    </string-array>
    <string-array name="tip_shields">
        <item>Purple Shields:</item>
        <item>   A shielded Pock</item>
        <item>   wins every bounce</item>
        <item>   so time your release!</item>
    </string-array>
    <string-array name="tip_overcharge">
        <item>Overcharge:</item>
        <item>   Charging too long</item>
        <item>   resets your power.</item>
        <item>   Don\'t hold forever!</item>
    </string-array>
    <string-array name="tip_grey">
        <item>Grey:</item>
        <item>   If your Pock turns grey</item>
        <item>   you can\'t strike it</item>
        <item>   unless timed correctly!</item>
    </string-array>

