    <!-- Tips shown during finger selection -->
    <string name="tip_title">准备好后按住此处</string>
    <string name="tip_controls">触摸屏幕并向后拉手指，将你的冰球弹射向前。</string>
    <string name="tip_scoring">将对手打入任一紫色球门区域并得分以赢得比赛。</string>
