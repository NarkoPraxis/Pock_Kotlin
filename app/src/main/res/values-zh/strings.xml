    <string-array name="tip_scoring">
        <item>得分：</item>
        <item>   将对手</item>
        <item>   打入紫色区域</item>
        <item>   即可得分。</item>
    </string-array>
    <string-array name="tip_charging">
        <item>蓄力：</item>
        <item>   按住蓄力。</item>
        <item>   变紫时松手</item>
        <item>   获得护盾！</item>
    </string-array>
    <string-array name="tip_shields">
        <item>紫色护盾：</item>
        <item>   有护盾的Pock</item>
        <item>   赢得每次碰撞</item>
        <item>   把握好时机！</item>
    </string-array>
    <string-array name="tip_overcharge">
        <item>过充：</item>
        <item>   蓄力太久</item>
        <item>   会重置力量。</item>
        <item>   别一直按着！</item>
    </string-array>
    <string-array name="tip_grey">
        <item>灰色：</item>
        <item>   如果你的Pock变灰</item>
        <item>   就无法击打</item>
        <item>   除非时机恰好！</item>
    </string-array>

