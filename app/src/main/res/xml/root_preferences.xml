<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Gameplay">
        <ListPreference
                android:summary="%s"
                android:defaultValue="default"
                android:entries="@array/ball_sizes"
                android:entryValues="@array/game_values"
                android:key="ball_sizes"
                android:title="Ball Size" />
        <ListPreference
                android:summary="%s"
                android:defaultValue="default"
                android:entries="@array/tail_lengths"
                android:entryValues="@array/game_values"
                android:key="tail_length"
                android:title="Tail Length" />
        <ListPreference
                android:summary="%s"
                android:defaultValue="default"
                android:entries="@array/bonus_durations"
                android:entryValues="@array/game_values"
                android:key="bonus_duration"
                android:title="Bonus Time" />
        <ListPreference
                android:summary="%1$s"
                android:defaultValue="default"
                android:entries="@array/bounce_bonuses"
                android:entryValues="@array/game_values"
                android:key="bounce_bonus"
                android:title="Power Bounce Bonus" />
        <ListPreference
                android:summary="%s"
                android:defaultValue="default"
                android:entries="@array/charge_speeds"
                android:entryValues="@array/game_values"
                android:key="charge_speed"
                android:title="Charge Speed" />
        <ListPreference
                android:summary="%s"
                android:defaultValue="default"
                android:entries="@array/game_speeds"
                android:entryValues="@array/game_values"
                android:key="game_speed"
                android:title="Game Speed" />
        <ListPreference
                android:summary="%s"
                android:defaultValue="slow"
                android:entries="@array/countdown_speeds"
                android:entryValues="@array/countdown_speed_values"
                android:key="countdown_speed"
                android:title="Countdown Speed" />
        <SwitchPreferenceCompat
                android:key="skip_finger_selection"
                android:title="Auto Restart"
                android:summary="Skip finger selection between rounds and reuse last picks"
                android:defaultValue="true" />
        <ListPreference
                app:key="points_to_win"
                app:title="Points to Win"
                app:summary="%s"
                app:entries="@array/points_to_win_entries"
                app:entryValues="@array/points_to_win_values"
                app:defaultValue="5" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Controls">
        <ListPreference
                android:summary="%s"
                android:defaultValue="fling"
                android:entries="@array/control_scheme_names"
                android:entryValues="@array/control_scheme_values"
                android:key="red_control_scheme"
                android:title="Red Control Scheme" />
        <ListPreference
                android:summary="%s"
                android:defaultValue="fling"
                android:entries="@array/control_scheme_names"
                android:entryValues="@array/control_scheme_values"
                android:key="blue_control_scheme"
                android:title="Blue Control Scheme" />
        <SwitchPreferenceCompat
                android:key="high_player_arrow"
                android:title="High Player Arrow"
                android:summary="Show aim arrow while charging (top player)"
                android:defaultValue="true" />
        <SwitchPreferenceCompat
                android:key="low_player_arrow"
                android:title="Low Player Arrow"
                android:summary="Show aim arrow while charging (bottom player)"
                android:defaultValue="true" />
    </PreferenceCategory>

    <PreferenceCategory app:title="Visual">
        <SwitchPreference
                android:defaultValue="false"
                android:key="darkmode"
                android:title="@string/darkmode_label" />
    </PreferenceCategory>

    <Preference android:title="Restore Defaults"
            android:summary=""
            android:key="restore_defaults"/>

</PreferenceScreen>
