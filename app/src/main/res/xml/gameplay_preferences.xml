<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto">

    <ListPreference
            android:summary="%s"
            android:defaultValue="default"
            android:entries="@array/ball_sizes"
            android:entryValues="@array/game_values"
            android:key="ball_sizes"
            android:title="@string/pref_ball_size_title" />
    <ListPreference
            android:summary="%s"
            android:defaultValue="default"
            android:entries="@array/charge_speeds"
            android:entryValues="@array/charge_speed_values"
            android:key="charge_speed"
            android:title="@string/pref_charge_speed_title" />
    <ListPreference
            android:summary="%s"
            android:defaultValue="default"
            android:entries="@array/game_speeds"
            android:entryValues="@array/game_values"
            android:key="game_speed"
            android:title="@string/pref_game_speed_title" />
    <com.runoutzone.pockpock.InfinitySeekBarPreference
            app:key="points_to_win"
            app:title="@string/pref_points_to_win_title"
            android:max="20"
            app:defaultValue="5"
            app:showSeekBarValue="true" />
    <com.runoutzone.pockpock.InfinitySeekBarPreference
            app:key="time_limit_minutes"
            app:title="@string/pref_time_limit_title"
            android:max="20"
            app:defaultValue="0"
            app:showSeekBarValue="true" />

</PreferenceScreen>
